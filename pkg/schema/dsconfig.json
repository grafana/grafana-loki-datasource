{
    "$schema": "https://raw.githubusercontent.com/grafana/dsconfig/refs/tags/dsconfig/v0.0.10/dsconfig/schema.json",
    "schemaVersion": "v1",
    "pluginType": "loki",
    "pluginName": "Loki",
    "docURL": "https://grafana.com/docs/grafana/latest/datasources/loki/",
    "fields": [
        {
            "id": "root_url",
            "key": "url",
            "label": "URL",
            "valueType": "string",
            "target": "root",
            "role": "endpoint.baseUrl",
            "required": true,
            "ui": {
                "component": "input",
                "placeholder": "http://localhost:3100"
            }
        },
        {
            "id": "virtual_authMethod",
            "key": "authMethod",
            "label": "Authentication method",
            "description": "Choose an authentication method to access the data source",
            "valueType": "string",
            "kind": "virtual",
            "defaultValue": "NoAuth",
            "validations": [
                {
                    "type": "allowedValues",
                    "values": [
                        "BasicAuth",
                        "OAuthForward",
                        "NoAuth"
                    ]
                }
            ],
            "ui": {
                "component": "select",
                "options": [
                    {
                        "label": "Basic authentication",
                        "value": "BasicAuth"
                    },
                    {
                        "label": "Forward OAuth Identity",
                        "value": "OAuthForward"
                    },
                    {
                        "label": "No Authentication",
                        "value": "NoAuth"
                    }
                ]
            },
            "storage": {
                "type": "computed",
                "read": "root.basicAuth == true ? 'BasicAuth' : (jsonData.oauthPassThru == true ? 'OAuthForward' : 'NoAuth')"
            },
            "effects": [
                {
                    "when": "value == 'BasicAuth'",
                    "set": {
                        "root_basicAuth": true,
                        "jsonData_oauthPassThru": false
                    }
                },
                {
                    "when": "value == 'OAuthForward'",
                    "set": {
                        "root_basicAuth": false,
                        "jsonData_oauthPassThru": true
                    }
                },
                {
                    "when": "value == 'NoAuth'",
                    "set": {
                        "root_basicAuth": false,
                        "jsonData_oauthPassThru": false
                    }
                }
            ]
        },
        {
            "id": "root_basicAuth",
            "key": "basicAuth",
            "valueType": "boolean",
            "target": "root",
            "role": "auth.basic.enabled",
            "defaultValue": false,
            "tags": [
                "managed-by:virtual_authMethod"
            ]
        },
        {
            "id": "root_basicAuthUser",
            "key": "basicAuthUser",
            "label": "User",
            "description": "The username of the data source account",
            "valueType": "string",
            "target": "root",
            "role": "auth.basic.username",
            "dependsOn": "virtual_authMethod == 'BasicAuth'",
            "requiredWhen": "root_basicAuth == true",
            "ui": {
                "component": "input",
                "placeholder": "User"
            }
        },
        {
            "id": "secureJsonData_basicAuthPassword",
            "key": "basicAuthPassword",
            "label": "Password",
            "description": "The password of the data source account",
            "valueType": "string",
            "target": "secureJsonData",
            "role": "auth.basic.password",
            "dependsOn": "virtual_authMethod == 'BasicAuth'",
            "requiredWhen": "root_basicAuth == true",
            "ui": {
                "component": "input",
                "placeholder": "Password"
            }
        },
        {
            "id": "jsonData_oauthPassThru",
            "key": "oauthPassThru",
            "valueType": "boolean",
            "target": "jsonData",
            "role": "auth.forwardOAuthToken.enabled",
            "defaultValue": false,
            "tags": [
                "managed-by:virtual_authMethod"
            ]
        },
        {
            "id": "jsonData_tlsAuthWithCACert",
            "key": "tlsAuthWithCACert",
            "label": "Add self-signed certificate",
            "description": "Add your own Certificate Authority (CA) certificate on top of one generated by the certificate authorities for additional security measures",
            "valueType": "boolean",
            "target": "jsonData",
            "defaultValue": false,
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "secureJsonData_tlsCACert",
            "key": "tlsCACert",
            "label": "CA Certificate",
            "description": "Your self-signed certificate",
            "valueType": "string",
            "target": "secureJsonData",
            "role": "tls.caCert",
            "dependsOn": "jsonData_tlsAuthWithCACert == true",
            "requiredWhen": "jsonData_tlsAuthWithCACert == true",
            "ui": {
                "component": "textarea",
                "multiline": true,
                "rows": 6,
                "placeholder": "Begins with --- BEGIN CERTIFICATE ---"
            }
        },
        {
            "id": "jsonData_tlsAuth",
            "key": "tlsAuth",
            "label": "TLS Client Authentication",
            "description": "Validate using TLS client authentication, in which the server authenticates the client",
            "valueType": "boolean",
            "target": "jsonData",
            "defaultValue": false,
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "jsonData_serverName",
            "key": "serverName",
            "label": "ServerName",
            "description": "A Servername is used to verify the hostname on the returned certificate",
            "valueType": "string",
            "target": "jsonData",
            "role": "tls.serverName",
            "dependsOn": "jsonData_tlsAuth == true",
            "requiredWhen": "jsonData_tlsAuth == true",
            "ui": {
                "component": "input",
                "placeholder": "domain.example.com"
            }
        },
        {
            "id": "secureJsonData_tlsClientCert",
            "key": "tlsClientCert",
            "label": "Client Certificate",
            "description": "The client certificate can be generated from a Certificate Authority or be self-signed",
            "valueType": "string",
            "target": "secureJsonData",
            "role": "tls.clientCert",
            "dependsOn": "jsonData_tlsAuth == true",
            "requiredWhen": "jsonData_tlsAuth == true",
            "ui": {
                "component": "textarea",
                "multiline": true,
                "rows": 6,
                "placeholder": "Begins with --- BEGIN CERTIFICATE ---"
            }
        },
        {
            "id": "secureJsonData_tlsClientKey",
            "key": "tlsClientKey",
            "label": "Client Key",
            "description": "The client key can be generated from a Certificate Authority or be self-signed",
            "valueType": "string",
            "target": "secureJsonData",
            "role": "tls.clientKey",
            "dependsOn": "jsonData_tlsAuth == true",
            "requiredWhen": "jsonData_tlsAuth == true",
            "ui": {
                "component": "textarea",
                "multiline": true,
                "rows": 6,
                "placeholder": "Begins with --- RSA PRIVATE KEY CERTIFICATE ---"
            }
        },
        {
            "id": "jsonData_tlsSkipVerify",
            "key": "tlsSkipVerify",
            "label": "Skip TLS certificate validation",
            "description": "Skipping TLS certificate validation is not recommended unless absolutely necessary or for testing",
            "valueType": "boolean",
            "target": "jsonData",
            "role": "transport.tlsSkipVerify",
            "defaultValue": false,
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "jsonData_keepCookies",
            "key": "keepCookies",
            "label": "Allowed cookies",
            "description": "Grafana proxy deletes forwarded cookies by default. Specify cookies by name that should be forwarded to the data source.",
            "valueType": "array",
            "target": "jsonData",
            "item": {
                "valueType": "string"
            },
            "ui": {
                "component": "list",
                "placeholder": "New cookie (hit enter to add)"
            }
        },
        {
            "id": "jsonData_timeout",
            "key": "timeout",
            "label": "Timeout",
            "description": "HTTP request timeout in seconds",
            "valueType": "number",
            "target": "jsonData",
            "role": "transport.timeoutSeconds",
            "ui": {
                "component": "input",
                "placeholder": "Timeout in seconds"
            }
        },
        {
            "id": "jsonData_httpHeaders",
            "key": "httpHeaders",
            "label": "Custom HTTP Headers",
            "description": "Additional HTTP headers sent with every request. Header names are stored in jsonData (httpHeaderName<N>); header values are write-only in secureJsonData (httpHeaderValue<N>).",
            "valueType": "array",
            "target": "jsonData",
            "role": "http.header",
            "item": {
                "valueType": "object",
                "fields": [
                    {
                        "id": "jsonData_httpHeaders.item.name",
                        "key": "name",
                        "label": "Header",
                        "valueType": "string",
                        "isItemField": true,
                        "role": "http.header.name",
                        "required": true,
                        "validations": [
                            {
                                "type": "pattern",
                                "pattern": "^[A-Za-z][A-Za-z0-9-]*$",
                                "message": "Header name must start with a letter and contain only letters, digits, or hyphens."
                            }
                        ],
                        "ui": {
                            "component": "input",
                            "placeholder": "X-Custom-Header"
                        }
                    },
                    {
                        "id": "jsonData_httpHeaders.item.value",
                        "key": "value",
                        "label": "Value",
                        "valueType": "string",
                        "isItemField": true,
                        "role": "http.header.value",
                        "ui": {
                            "component": "input",
                            "placeholder": "Header Value"
                        }
                    }
                ]
            },
            "storage": {
                "type": "indexedPair",
                "key": {
                    "target": "jsonData",
                    "pattern": "httpHeaderName{index}"
                },
                "value": {
                    "target": "secureJsonData",
                    "pattern": "httpHeaderValue{index}"
                },
                "startIndex": 1
            }
        },
        {
            "id": "jsonData_manageAlerts",
            "key": "manageAlerts",
            "label": "Manage alert rules in Alerting UI",
            "description": "Manage alert rules for this data source. To manage other alerting resources, add an Alertmanager data source.",
            "valueType": "boolean",
            "target": "jsonData",
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "jsonData_maxLines",
            "key": "maxLines",
            "label": "Maximum lines",
            "description": "Loki queries must contain a limit of the maximum number of lines returned (default: 1000). Increase this limit to have a bigger result set for ad-hoc analysis. Decrease this limit if your browser becomes sluggish when displaying the log results.",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input",
                "placeholder": "1000"
            }
        },
        {
            "id": "jsonData_derivedFields",
            "key": "derivedFields",
            "label": "Derived fields",
            "description": "Derived fields can be used to extract new fields from a log message and create a link from its value.",
            "valueType": "array",
            "target": "jsonData",
            "item": {
                "valueType": "object",
                "fields": [
                    {
                        "id": "jsonData_derivedFields.item.name",
                        "key": "name",
                        "label": "Name",
                        "valueType": "string",
                        "isItemField": true,
                        "required": true,
                        "ui": {
                            "component": "input",
                            "placeholder": "Field name"
                        }
                    },
                    {
                        "id": "jsonData_derivedFields.item.matcherType",
                        "key": "matcherType",
                        "label": "Type",
                        "description": "Derived fields can be created from labels or by applying a regular expression to the log message.",
                        "valueType": "string",
                        "isItemField": true,
                        "defaultValue": "regex",
                        "validations": [
                            {
                                "type": "allowedValues",
                                "values": [
                                    "regex",
                                    "label"
                                ]
                            }
                        ],
                        "ui": {
                            "component": "select",
                            "options": [
                                {
                                    "label": "Regex in log line",
                                    "value": "regex"
                                },
                                {
                                    "label": "Label",
                                    "value": "label"
                                }
                            ]
                        }
                    },
                    {
                        "id": "jsonData_derivedFields.item.matcherRegex",
                        "key": "matcherRegex",
                        "label": "Regex",
                        "description": "Use to parse and capture some part of the log message. You can use the captured groups in the template.",
                        "valueType": "string",
                        "isItemField": true,
                        "required": true,
                        "ui": {
                            "component": "input"
                        }
                    },
                    {
                        "id": "jsonData_derivedFields.item.url",
                        "key": "url",
                        "label": "URL",
                        "valueType": "string",
                        "isItemField": true,
                        "ui": {
                            "component": "input",
                            "placeholder": "http://example.com/${__value.raw}"
                        }
                    },
                    {
                        "id": "jsonData_derivedFields.item.urlDisplayLabel",
                        "key": "urlDisplayLabel",
                        "label": "URL Label",
                        "description": "Use to override the button label when this derived field is found in a log.",
                        "valueType": "string",
                        "isItemField": true,
                        "ui": {
                            "component": "input"
                        }
                    },
                    {
                        "id": "jsonData_derivedFields.item.datasourceUid",
                        "key": "datasourceUid",
                        "label": "Data source",
                        "description": "The tracing data source this internal link should navigate to. Setting this makes the derived field an internal link.",
                        "valueType": "string",
                        "isItemField": true,
                        "ui": {
                            "component": "input"
                        }
                    },
                    {
                        "id": "jsonData_derivedFields.item.targetBlank",
                        "key": "targetBlank",
                        "label": "Open in new tab",
                        "valueType": "boolean",
                        "isItemField": true,
                        "ui": {
                            "component": "switch"
                        }
                    }
                ]
            }
        }
    ],
    "groups": [
        {
            "id": "connection",
            "title": "Connection",
            "order": 1,
            "fieldRefs": [
                "root_url"
            ]
        },
        {
            "id": "authentication",
            "title": "Authentication",
            "order": 2,
            "fieldRefs": [
                "virtual_authMethod",
                "root_basicAuthUser",
                "secureJsonData_basicAuthPassword"
            ]
        },
        {
            "id": "tls-settings",
            "title": "TLS settings",
            "order": 3,
            "optional": true,
            "fieldRefs": [
                "jsonData_tlsAuthWithCACert",
                "secureJsonData_tlsCACert",
                "jsonData_tlsAuth",
                "jsonData_serverName",
                "secureJsonData_tlsClientCert",
                "secureJsonData_tlsClientKey",
                "jsonData_tlsSkipVerify"
            ]
        },
        {
            "id": "advanced-http",
            "title": "Advanced HTTP settings",
            "order": 4,
            "optional": true,
            "fieldRefs": [
                "jsonData_keepCookies",
                "jsonData_timeout",
                "jsonData_httpHeaders"
            ]
        },
        {
            "id": "alerting",
            "title": "Alerting",
            "order": 5,
            "optional": true,
            "fieldRefs": [
                "jsonData_manageAlerts"
            ]
        },
        {
            "id": "queries",
            "title": "Queries",
            "order": 6,
            "optional": true,
            "fieldRefs": [
                "jsonData_maxLines"
            ]
        },
        {
            "id": "derived-fields",
            "title": "Derived fields",
            "order": 7,
            "optional": true,
            "fieldRefs": [
                "jsonData_derivedFields"
            ]
        }
    ],
    "relationships": [
        {
            "type": "pair",
            "fields": [
                "root_basicAuthUser",
                "secureJsonData_basicAuthPassword"
            ],
            "description": "Basic auth credentials. Both fields are used together when root.basicAuth is true."
        },
        {
            "type": "group",
            "fields": [
                "jsonData_tlsAuth",
                "jsonData_serverName",
                "secureJsonData_tlsClientCert",
                "secureJsonData_tlsClientKey"
            ],
            "description": "TLS mutual auth: enabling jsonData.tlsAuth requires serverName + client cert + client key. See @grafana/plugin-ui TLSClientAuth.tsx."
        },
        {
            "type": "pair",
            "fields": [
                "jsonData_tlsAuthWithCACert",
                "secureJsonData_tlsCACert"
            ],
            "description": "Self-signed / custom CA verification: enabling jsonData.tlsAuthWithCACert requires the CA certificate PEM in secureJsonData.tlsCACert."
        }
    ],
    "instructions": [
        {
            "msg": "Loki authentication is built on Grafana's HTTP settings model, not a discriminator field. The editor's three visible auth methods write these flags: 'Basic authentication' sets root.basicAuth=true and provides root.basicAuthUser + secureJsonData.basicAuthPassword; 'Forward OAuth Identity' sets jsonData.oauthPassThru=true; 'No Authentication' leaves both false. Only one of basicAuth / oauthPassThru should be true at a time — the editor's onAuthMethodSelect (@grafana/plugin-ui utils.ts:44-54) always writes both. The upstream utility convertLegacyAuthProps also recognises root.withCredentials for 'cross-site access control', but this plugin does not offer it in its visibleMethods (default [BasicAuth, OAuthForward, NoAuth]).",
            "tags": [
                "llm",
                "auth"
            ]
        },
        {
            "msg": "Minimal Basic-auth payload: {\"url\":\"http://localhost:3100\",\"basicAuth\":true,\"basicAuthUser\":\"<user>\",\"jsonData\":{},\"secureJsonData\":{\"basicAuthPassword\":\"<password>\"}}. Minimal No-auth payload: {\"url\":\"http://localhost:3100\",\"jsonData\":{}}. Minimal OAuth-forward payload: {\"url\":\"http://localhost:3100\",\"jsonData\":{\"oauthPassThru\":true}}. root.url is required — the Loki backend reads settings.URL directly (pkg/loki/loki.go:66) and issues requests against '<url>/loki/api/v1/...'. Trailing slashes on the URL are safe.",
            "tags": [
                "llm",
                "auth"
            ]
        },
        {
            "msg": "TLS is independent of the auth method. jsonData.tlsAuth=true enables mTLS and requires jsonData.serverName plus secureJsonData.tlsClientCert and secureJsonData.tlsClientKey. jsonData.tlsAuthWithCACert=true enables server-cert verification against a custom CA and requires secureJsonData.tlsCACert. Both can be enabled together. jsonData.tlsSkipVerify=true bypasses verification entirely and should only be used for testing. All TLS fields are consumed by the SDK's settings.HTTPClientOptions(ctx) call in pkg/loki/loki.go:51.",
            "tags": [
                "llm",
                "tls"
            ]
        },
        {
            "msg": "secureJsonData values (basicAuthPassword, tlsCACert, tlsClientCert, tlsClientKey) are write-only: they can be set or reset but never read back. To check whether a secret is already configured on an existing datasource, read the secureJsonFields object (e.g. secureJsonFields.basicAuthPassword == true) instead of secureJsonData. Custom HTTP headers are modeled by the jsonData_httpHeaders array field using an indexedPair storage mapping: each header's name is written to jsonData.httpHeaderName<N> and its value is written write-only to secureJsonData.httpHeaderValue<N> (starting at N=1), exactly as @grafana/plugin-ui's CustomHeaders component and the SDK HTTPClientOptions expect. The per-header httpHeaderValue<N> secrets are dynamic and are therefore not listed among the static SecureJsonDataKeys.",
            "tags": [
                "llm",
                "auth",
                "secure"
            ]
        },
        {
            "msg": "Loki-specific query knobs are frontend-only. jsonData.maxLines (string, default '1000') is parsed by the frontend datasource (src/datasource.ts:168) into an integer limit that is appended to each Loki query at request time — the Loki backend never reads it from settings; it takes the limit from the per-query LokiDataQuery.MaxLines field. jsonData.derivedFields is applied by the frontend result transformer (src/datasource.ts:397) to build data links on log rows and is likewise not read server-side. Setting them via provisioning still works because the editor renders whatever is in jsonData.",
            "tags": [
                "llm",
                "settings"
            ]
        },
        {
            "msg": "jsonData.manageAlerts controls whether Grafana's Alerting UI can create alert rules against this Loki datasource. It is a Grafana-core setting read from DataSourceJsonData, not by the Loki plugin's own Go code. Custom HTTP headers are now modeled as a first-class jsonData_httpHeaders array field (indexedPair storage: httpHeaderName<N> in jsonData / httpHeaderValue<N> in secureJsonData, starting at index 1), as written by @grafana/plugin-ui's CustomHeaders component and forwarded to Loki by the SDK's HTTPClientOptions. jsonData.alertmanager exists on the frontend LokiOptions type (src/types.ts:39) but is neither rendered by the editor nor read by the datasource — treat it as dead storage.",
            "tags": [
                "llm",
                "settings",
                "legacy"
            ]
        }
    ]
}
